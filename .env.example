# Shared
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# API
PORT=4000
DATABASE_URL=postgresql://anonchat:anonchat@localhost:5432/anonchat?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes
JWT_REFRESH_SECRET=replace-with-at-least-32-random-bytes
TOKEN_HASH_SECRET=replace-with-at-least-32-random-bytes
COOKIE_SECRET=replace-with-at-least-32-random-bytes
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
MAGIC_LINK_DEV_MODE=true
RETENTION_SWEEP_INTERVAL_MS=60000
MAX_UPLOAD_BYTES=26214400

# Optional moderation provider
MODERATION_WEBHOOK_URL=
MODERATION_WEBHOOK_TOKEN=

# S3-compatible storage: Cloudflare R2, AWS S3, MinIO, etc.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=anonymous-chat-media
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
