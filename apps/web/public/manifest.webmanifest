  "screenshots": [
    {
      "src": "/splash.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "NoTrace splash screen"
    }
  ],
  "shortcuts": [
    {
      "name": "Join a Group",
      "short_name": "Join",
      "description": "Join an anonymous group with an invite code",
      "url": "/join",
