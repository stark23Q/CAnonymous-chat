{
  "name": "NoTrace – Anonymous Community Chat",
  "short_name": "NoTrace",
  "description": "Invite-only anonymous community chat. Speak freely. Leave no trace.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#000000",
  "theme_color": "#8B4AFF",
  "categories": ["social", "communication"],
  "lang": "en",
  "dir": "ltr",
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
